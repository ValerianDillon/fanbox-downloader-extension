{
  "manifest_version": 3,
  "name": "FANBOX Downloader",
  "version": "1.0.0",
  "description": "pixiv FANBOX の投稿を ZIP として一括ダウンロード",
  "permissions": ["declarativeNetRequest"],
  "host_permissions": ["*://*.fanbox.cc/*", "*://*.pximg.net/*"],
  "content_scripts": [
    {
      "matches": ["*://*.fanbox.cc/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "fanbox_origin_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
